{
  "name": "nutripair-ios",
  "version": "1.0.0",
  "private": true,
  "description": "Capacitor iOS wrapper for NutriPair — loads the live Cloudflare Worker in a native WKWebView, adds push-notification entitlements.",
  "scripts": {
    "cap:add": "cap add ios",
    "cap:sync": "cap sync ios",
    "cap:copy": "cap copy ios",
    "cap:open": "cap open ios",
    "assets": "capacitor-assets generate --ios --iconBackgroundColor '#2d9e5f' --iconBackgroundColorDark '#2d9e5f'"
  },
  "dependencies": {
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/push-notifications": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0"
  }
}
