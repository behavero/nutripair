{
  "name": "nutripair",
  "version": "2.0.0",
  "private": true,
  "description": "Shared grocery list + weekly meal plan for two — Cloudflare Worker + KV",
  "scripts": {
    "dev": "wrangler dev --no-bundle",
    "deploy": "wrangler deploy --no-bundle",
    "tail": "wrangler tail",
    "kv:get": "wrangler kv key get --binding=KV state",
    "kv:reset": "wrangler kv key delete --binding=KV state"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
